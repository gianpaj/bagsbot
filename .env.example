# Bags API Configuration
BAGS_API_KEY=your_bags_api_key_here

# Solana RPC Configuration
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Wallet Configuration
WALLET_PATH=/path/to/your/wallet.json

# Launch Source Configuration
# Use "live" for the real Bags restream or "scenario" for synthetic test launches
LAUNCH_SOURCE=live

# Scenario Configuration (used when LAUNCH_SOURCE=scenario)
SCENARIO_NAME=mixed-opportunities
SCENARIO_INTERVAL_MS=2500
SCENARIO_DISABLE_TRADING=true
