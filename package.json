{
  "name": "bagsbot",
  "version": "1.0.0",
  "description": "Bags Sniper Bot - A CLI bot for monitoring Solana token launches on the Bags platform",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "bun --env-file=.env src/index.ts",
    "dev:scenario": "LAUNCH_SOURCE=scenario bun --env-file=.env src/index.ts",
    "scenario:mixed": "LAUNCH_SOURCE=scenario SCENARIO_NAME=mixed-opportunities bun --env-file=.env src/index.ts",
    "simulate": "bun --env-file=.env src/simulate.ts",
    "simulate:history": "bun --env-file=.env src/simulate-history.ts",
    "top-tokens": "bun --env-file=.env src/cli/top-tokens.tsx",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "solana",
    "bags",
    "sniper",
    "bot",
    "cli"
  ],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^25.0.10",
    "@types/react": "^19.2.14",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.39.2",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@bagsfm/bags-sdk": "^1.3.1",
    "@opentui/core": "^0.1.75",
    "@solana/web3.js": "^1.98.4",
    "ink": "^6.8.0",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  }
}
